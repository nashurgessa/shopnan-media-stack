# Copy to .env and set strong secrets before starting.
#   cp .env.example .env

# --- MinIO ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_BUCKET=shopnan-media

# Service account used by Flask uploads (Phase 6)
FLASK_S3_ACCESS_KEY=flask-upload
FLASK_S3_SECRET_KEY=change-me-flask-upload-secret

# Service account used by imgproxy reads
IMGPROXY_S3_ACCESS_KEY=imgproxy-read
IMGPROXY_S3_SECRET_KEY=change-me-imgproxy-read-secret

# --- imgproxy ---
IMGPROXY_QUALITY=80
IMGPROXY_MAX_SRC_RESOLUTION=50
IMGPROXY_MAX_SRC_FILE_SIZE=10485760
IMGPROXY_CONCURRENCY=4

# --- CDN / NGINX ---
CDN_HTTP_PORT=8088
CDN_SERVER_NAME=cdn.shopnan.com

# Public CDN base (local dev below; production: https://cdn.shopnan.com)
CDN_BASE_URL=http://localhost:8088
