# ── MinIO (object storage) ──────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_BUCKET=shopnan-media

# Backend upload credentials (must match app S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY)
FLASK_S3_ACCESS_KEY=flask-upload
FLASK_S3_SECRET_KEY=change-me-flask-upload-secret

# imgproxy read-only credentials
IMGPROXY_S3_ACCESS_KEY=imgproxy-read
IMGPROXY_S3_SECRET_KEY=change-me-imgproxy-read-secret

# ── CDN (NGINX) ─────────────────────────────────────────────────────────────
# Local dev: 8088  |  Production behind Cloudflare: 80
CDN_HTTP_PORT=8088
CDN_SERVER_NAME=cdn.shopnan.com
CDN_BASE_URL=http://localhost:8088

# imgproxy signing (optional — nginx uses /insecure/ on the internal Docker network)
IMGPROXY_KEY=
IMGPROXY_SALT=
